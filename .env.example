# ═══════════════════════════════════════════════════════════════
# Zvision CRM — Environment Variables
# ═══════════════════════════════════════════════════════════════

# Supabase — Autenticacao e Banco de Dados
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key  # NEVER expose to client

# IA — Briefing Generation (Groq + LLaMA)
GROQ_API_KEY=your_groq_api_key  # Get from console.groq.com

# Web Scraping (Opcional — usado para enrichment de leads)
APIFY_TOKEN=your_apify_token

# Legacy — Gemini API (substituido por Groq)
# GEMINI_API_KEY=your_gemini_api_key
